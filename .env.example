# Neon (Postgres)
DATABASE_URL=

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


# Each bucket gets its own pub-xxx.r2.dev subdomain when public access is enabled.
# Copy the URL Cloudflare shows after enabling public access on each bucket.
R2_PUBLIC_URL_GLB=
R2_PUBLIC_URL_MEDIA=

# Cloudflare R2 (storage) — critical path, configured by deploy-ops in Slice 1
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_GLB=forge-glb
R2_BUCKET_MEDIA=forge-media

# Plausible Analytics — optional. If unset, no analytics script is loaded.
# Set to your Plausible site's domain (e.g. forge-black-eta.vercel.app).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
